<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>
<?import com.skilora.framework.components.*?>
<?import com.skilora.framework.components.TLSeparator?>

<VBox xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.skilora.community.controller.ErrorController"
      spacing="32"
      alignment="CENTER"
      styleClass="transparent-bg">
    
    <padding><Insets top="80" right="32" bottom="80" left="32"/></padding>
    
    <VBox spacing="16" alignment="CENTER">
        <Label fx:id="errorIcon" text="" styleClass="error-icon"/>
        <Label fx:id="errorCode" text="" styleClass="h1, error-code"/>
    </VBox>
    
    <VBox spacing="12" alignment="CENTER" maxWidth="600">
        <Label fx:id="errorTitle" text="" styleClass="h2" alignment="CENTER"/>
        <Label fx:id="errorMessage" text="" styleClass="text-muted" wrapText="true" alignment="CENTER"/>
    </VBox>
    
    <VBox spacing="12" alignment="CENTER">
        <TLButton fx:id="homeBtn" text="" variant="PRIMARY" onAction="#handleGoHome"/>
        <TLButton fx:id="backBtn" text="" variant="OUTLINE" onAction="#handleGoBack"/>
    </VBox>
    
    <VBox spacing="8" alignment="CENTER">
        <TLSeparator maxWidth="300"/>
        <Label fx:id="needHelpLabel" text="" styleClass="text-muted"/>
        <TLButton fx:id="supportBtn" text="" variant="GHOST" onAction="#handleSupport"/>
    </VBox>
    
    <VBox fx:id="detailsBox" spacing="8" alignment="CENTER" visible="false" managed="false">
        <TLSeparator maxWidth="400"/>
        <Label fx:id="techDetailsLabel" text="" styleClass="text-muted, text-xs"/>
        <Label fx:id="technicalDetails" text="" styleClass="text-muted, text-xs-mono" wrapText="true"/>
    </VBox>
</VBox>
