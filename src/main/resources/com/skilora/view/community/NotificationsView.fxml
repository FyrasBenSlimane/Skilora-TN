<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>
<?import com.skilora.framework.components.*?>

<VBox xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.skilora.community.controller.NotificationsController"
      spacing="24"
      styleClass="transparent-bg">
    <padding><Insets top="32" right="32" bottom="32" left="32"/></padding>
    
    <HBox spacing="24" alignment="CENTER_LEFT">
        <VBox spacing="4">
            <Label text="" styleClass="h2"/>
            <Label fx:id="statsLabel" text="" styleClass="text-muted"/>
        </VBox>
        <Region HBox.hgrow="ALWAYS"/>
        <HBox spacing="12">
            <TLButton fx:id="markAllBtn" text="" variant="OUTLINE" onAction="#handleMarkAllRead"/>
            <TLButton fx:id="clearBtn" text="" variant="GHOST" onAction="#handleClearAll"/>
        </HBox>
    </HBox>
    
    <HBox fx:id="tabsBox" spacing="8">
        <TLButton fx:id="allTab" text="" variant="GHOST" styleClass="tab-button, tab-button-active" onAction="#handleShowAll"/>
        <TLButton fx:id="unreadTab" text="" variant="GHOST" styleClass="tab-button" onAction="#handleShowUnread"/>
        <TLButton fx:id="mentionsTab" text="" variant="GHOST" styleClass="tab-button" onAction="#handleShowMentions"/>
    </HBox>
    
    <ScrollPane fitToWidth="true" styleClass="transparent-bg" VBox.vgrow="ALWAYS">
        <VBox fx:id="notificationsList" spacing="12">
            <padding><Insets top="0" right="8" bottom="0" left="0"/></padding>
        </VBox>
    </ScrollPane>
</VBox>
