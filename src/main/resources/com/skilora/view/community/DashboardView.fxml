<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import com.skilora.framework.components.*?>

<VBox xmlns:fx="http://javafx.com/fxml/1" 
      fx:controller="com.skilora.community.controller.DashboardController"
      spacing="28" fillWidth="true">
    
    <padding>
        <Insets top="32" right="32" bottom="32" left="32"/>
    </padding>

    <!-- Greeting header -->
    <VBox spacing="4" fx:id="headerSection">
        <Label fx:id="greetingLabel" styleClass="h2"/>
        <Label fx:id="subGreetingLabel" styleClass="text-muted"/>
    </VBox>

    <!-- Quick Actions -->
    <VBox spacing="12" fx:id="quickActionsSection">
        <Label fx:id="quickActionsLabel" text="" styleClass="h4"/>
        <FlowPane fx:id="actionsContainer" hgap="10" vgap="10"/>
    </VBox>

    <!-- Statistics Cards -->
    <VBox spacing="12" fx:id="statsSection">
        <Label fx:id="statsHeaderLabel" text="" styleClass="h4"/>
        <FlowPane fx:id="statsGrid" hgap="16" vgap="16"/>
    </VBox>

    <!-- Recent Activity -->
    <VBox spacing="12" fx:id="activitySection" VBox.vgrow="ALWAYS">
        <Label fx:id="activityHeaderLabel" text="" styleClass="h4"/>
        <TLCard>
             <VBox fx:id="activityList" spacing="0"/>
        </TLCard>
    </VBox>

</VBox>
