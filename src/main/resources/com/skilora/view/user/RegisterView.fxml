<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.shape.SVGPath?>
<?import javafx.geometry.Insets?>
<?import com.skilora.framework.components.TLTextField?>
<?import com.skilora.framework.components.TLPasswordField?>
<?import com.skilora.framework.components.TLButton?>

<HBox xmlns:fx="http://javafx.com/fxml/1" 
      fx:controller="com.skilora.user.controller.RegisterController"
      styleClass="app-root"
      fillHeight="true">
    
    <StackPane fx:id="heroContainer" styleClass="auth-hero" 
               prefWidth="500" minWidth="400" alignment="CENTER">
        <HBox.hgrow>ALWAYS</HBox.hgrow>
        
        <VBox alignment="BOTTOM_LEFT" maxHeight="Infinity">
            <padding><Insets top="48" right="48" bottom="48" left="48"/></padding>
            
            <HBox spacing="12" alignment="CENTER_LEFT">
                <SVGPath content="M12 2L2 7l10 5 10-5-10-5zm0 9l2.5-1.25L12 8.5l-2.5 1.25L12 11zm0 2.5l-5-2.5-5 2.5L12 22l10-8.5-5-2.5-5 2.5z" 
                         styleClass="hero-icon" scaleX="1.5" scaleY="1.5"/>
                <Label fx:id="heroBrandLabel" text="" styleClass="hero-brand"/>
            </HBox>
            
            <Region VBox.vgrow="ALWAYS"/>
            
            <VBox spacing="16">
                <Label fx:id="heroHeadingLabel" text="" styleClass="hero-heading" wrapText="true"/>
                <Label fx:id="heroSubtitleLabel" text="" styleClass="hero-subtitle"/>
            </VBox>
        </VBox>
    </StackPane>
    
    <StackPane minWidth="400" alignment="CENTER">
        <HBox.hgrow>ALWAYS</HBox.hgrow>
        
        <VBox spacing="24" maxWidth="380" alignment="CENTER_LEFT">
            <VBox spacing="8" alignment="CENTER_LEFT">
                <Label fx:id="formTitleLabel" text="" styleClass="h2"/>
                <Label fx:id="formSubtitleLabel" text="" styleClass="text-muted"/>
            </VBox>
            
            <Label fx:id="errorLabel" visible="false" managed="false" styleClass="text-sm, text-destructive"/>

            <HBox fx:id="roleToggle" spacing="0" alignment="CENTER" styleClass="role-toggle">
                <TLButton fx:id="freelancerBtn" text="I want to work" variant="PRIMARY"
                          onAction="#selectFreelancer" HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
                <TLButton fx:id="clientBtn" text="I want to hire" variant="OUTLINE"
                          onAction="#selectClient" HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
            </HBox>

            <TLTextField fx:id="fullNameField" label="" promptText=""/>
            <TLTextField fx:id="usernameField" label="" promptText=""/>
            <TLTextField fx:id="emailField" label="" promptText=""/>
            <TLPasswordField fx:id="passwordField" label="" promptText=""/>
            <TLPasswordField fx:id="confirmPasswordField" label="" promptText=""/>
            
            <TLButton fx:id="registerBtn" text="" variant="PRIMARY" maxWidth="Infinity" onAction="#handleRegister"/>
            
            <HBox alignment="CENTER">
                <Label fx:id="dividerLabel" text="" styleClass="text-xs, text-muted"/>
            </HBox>
            
            <HBox spacing="4" alignment="CENTER">
                <Label fx:id="alreadyAccountLabel" text="" styleClass="text-muted"/>
                <TLButton fx:id="loginLink" text="" variant="GHOST" styleClass="link-inline" onAction="#openLogin"/>
            </HBox>
        </VBox>
    </StackPane>
</HBox>
