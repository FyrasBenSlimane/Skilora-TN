<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import com.skilora.framework.components.*?>
<?import com.skilora.framework.components.TLSeparator?>

<fx:root type="VBox" xmlns:fx="http://javafx.com/fxml/1" 
      fx:controller="com.skilora.user.controller.ProfileWizardController"
      spacing="24" fillWidth="true">
    
    <padding>
        <Insets top="32" right="32" bottom="32" left="32"/>
    </padding>

    <VBox spacing="8">
        <HBox alignment="CENTER_LEFT" spacing="16">
            <Label fx:id="profileTitleLabel" text="" styleClass="h2"/>
            <Region HBox.hgrow="ALWAYS" />
            <TLButton fx:id="viewPublicProfileBtn" text="View Public Profile" variant="OUTLINE" icon="EYE" />
        </HBox>
        <Label fx:id="profileSubtitleLabel" text="" styleClass="text-muted"/>
    </VBox>

    <TLSeparator/>

    <ScrollPane fitToWidth="true" styleClass="transparent-bg" VBox.vgrow="ALWAYS">
        <VBox spacing="24">

            <VBox spacing="16">
                <Label fx:id="photoSectionLabel" text="" styleClass="h4"/>
                <HBox spacing="20" alignment="CENTER_LEFT">
                    <TLAvatar fx:id="photoAvatar"/>
                    <VBox spacing="8" HBox.hgrow="ALWAYS">
                        <HBox spacing="12" alignment="CENTER_LEFT">
                            <TLButton fx:id="uploadPhotoBtn" text="" onAction="#handleUploadPhoto"/>
                            <TLButton fx:id="removePhotoBtn" text="" variant="GHOST" onAction="#handleRemovePhoto"/>
                        </HBox>
                        <Label fx:id="photoStatusLabel" text="" styleClass="text-muted, text-xs"/>
                    </VBox>
                </HBox>
            </VBox>

            <VBox spacing="16">
                <Label fx:id="cvSectionLabel" text="" styleClass="h4"/>
                <HBox spacing="12" alignment="CENTER_LEFT">
                    <TLButton fx:id="uploadCvBtn" text="" onAction="#handleUploadCv"/>
                    <TLButton fx:id="removeCvBtn" text="" variant="GHOST" onAction="#handleRemoveCv"/>
                </HBox>
                <Label fx:id="cvStatusLabel" text="" styleClass="text-muted, text-xs"/>
            </VBox>

            <TLSeparator/>
            
            <VBox spacing="16">
                <Label fx:id="personalInfoLabel" text="" styleClass="h4"/>
                
                <GridPane hgap="16" vgap="16">
                    <columnConstraints>
                        <ColumnConstraints percentWidth="50"/>
                        <ColumnConstraints percentWidth="50"/>
                    </columnConstraints>
                    
                    <TLTextField fx:id="firstNameField" label="" promptText="" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                    <TLTextField fx:id="lastNameField" label="" promptText="" GridPane.columnIndex="1" GridPane.rowIndex="0"/>
                    
                    <TLTextField fx:id="headlineField" label="" promptText="" GridPane.columnSpan="2" GridPane.rowIndex="1"/>
                </GridPane>
                
                <VBox spacing="8">
                    <Label fx:id="bioLabel" text="" styleClass="text-sm, font-bold"/>
                    <TLTextarea fx:id="bioArea" promptText=""/>
                </VBox>
            </VBox>

            <TLSeparator/>

            <VBox spacing="16">
                <Label fx:id="contactLabel" text="" styleClass="h4"/>
                <GridPane hgap="16" vgap="16">
                     <columnConstraints>
                        <ColumnConstraints percentWidth="50"/>
                        <ColumnConstraints percentWidth="50"/>
                    </columnConstraints>
                    
                    <TLTextField fx:id="emailField" label="" disable="true" GridPane.columnIndex="0"/>
                    <TLTextField fx:id="phoneField" label="" promptText="" GridPane.columnIndex="1"/>
                    <TLTextField fx:id="locationField" label="" promptText="" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
                    <TLTextField fx:id="websiteField" label="" promptText="" GridPane.columnIndex="1" GridPane.rowIndex="1"/>
                </GridPane>
            </VBox>

            <TLSeparator/>

            <VBox spacing="16">
                <Label fx:id="skillsSectionLabel" text="" styleClass="h4"/>

                <HBox spacing="12" alignment="CENTER_LEFT">
                    <TLTextField fx:id="skillNameField" label="" promptText="" HBox.hgrow="ALWAYS"/>
                    <TLSelect fx:id="skillLevelSelect" minWidth="170"/>
                    <TLButton fx:id="addSkillBtn" text="" variant="OUTLINE"/>
                </HBox>

                <FlowPane fx:id="skillsContainer" hgap="8" vgap="8" prefWrapLength="680"/>
            </VBox>

            <TLSeparator/>

            <VBox spacing="16">
                <HBox spacing="12" alignment="CENTER_LEFT">
                    <Label fx:id="experienceSectionLabel" text="" styleClass="h4"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <TLButton fx:id="addExperienceBtn" text="" variant="OUTLINE"/>
                </HBox>

                <VBox fx:id="experienceList" spacing="12"/>
            </VBox>

            <TLSeparator/>

            <VBox spacing="16">
                <HBox spacing="12" alignment="CENTER_LEFT">
                    <Label fx:id="portfolioSectionLabel" text="Portfolio" styleClass="h4"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <TLButton fx:id="addPortfolioBtn" text="Add Item" variant="OUTLINE"/>
                </HBox>

                <FlowPane fx:id="portfolioList" hgap="12" vgap="12" prefWrapLength="600"/>
            </VBox>

            <TLSeparator/>

            <VBox spacing="16">
                <Label fx:id="biometricSectionLabel" text="" styleClass="h4"/>
                <Label fx:id="biometricDescLabel" text="" styleClass="text-muted"/>
                
                <HBox spacing="16" alignment="CENTER_LEFT">
                    <VBox spacing="8" HBox.hgrow="ALWAYS">
                        <Label fx:id="biometricStatusLabel" text="" styleClass="text-sm"/>
                    </VBox>
                    <TLButton fx:id="biometricBtn" text="" onAction="#handleBiometricSetup"/>
                </HBox>
            </VBox>

        </VBox>
    </ScrollPane>

    <TLSeparator/>

    <HBox fx:id="actionsBar" spacing="16" alignment="CENTER_RIGHT" visible="false" managed="false">
        <Label fx:id="statusLabel" styleClass="text-muted"/>
        <Region HBox.hgrow="ALWAYS"/>
        <TLButton fx:id="cancelBtn" text="" variant="OUTLINE" onAction="#handleCancel"/>
        <TLButton fx:id="saveBtn" text="" onAction="#handleSave"/>
    </HBox>

</fx:root>
