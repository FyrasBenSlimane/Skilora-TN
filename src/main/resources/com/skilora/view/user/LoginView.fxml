<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.shape.SVGPath?>
<?import com.skilora.framework.components.*?>

<HBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.skilora.user.controller.LoginController"
      styleClass="app-root"
      fillHeight="true">

    <!-- LEFT SIDE (Hero) -->
    <StackPane fx:id="heroContainer" minWidth="400" prefWidth="500" styleClass="auth-hero">
         <!-- Video content added by controller at index 0 -->
         
         <!-- Overlay Content -->
         <VBox alignment="BOTTOM_LEFT" spacing="16" styleClass="hero-content">
             <HBox spacing="12" alignment="CENTER_LEFT">
                 <SVGPath content="M12 2L2 7l10 5 10-5-10-5zm0 9l2.5-1.25L12 8.5l-2.5 1.25L12 11zm0 2.5l-5-2.5-5 2.5L12 22l10-8.5-5-2.5-5 2.5z" 
                          styleClass="hero-icon" scaleX="1.5" scaleY="1.5"/>
                 <Label fx:id="heroBrand" text="" styleClass="hero-brand"/>
             </HBox>
             
             <Region VBox.vgrow="ALWAYS"/>
             
             <VBox spacing="16">
                 <Label fx:id="heroHeading" text="" wrapText="true" styleClass="hero-heading"/>
                 <Label fx:id="heroSubtitle" text="" styleClass="hero-subtitle"/>
             </VBox>
         </VBox>
    </StackPane>

    <!-- RIGHT SIDE (Form) -->
    <StackPane HBox.hgrow="ALWAYS" alignment="CENTER" minWidth="400">
        <VBox maxWidth="380" spacing="24" alignment="CENTER_LEFT">
            <VBox spacing="8" alignment="CENTER_LEFT">
                <Label fx:id="welcomeTitle" text="" styleClass="h2"/>
                <Label fx:id="welcomeSubtitle" text="" styleClass="text-muted"/>
            </VBox>
            
            <Label fx:id="errorLabel" visible="false" managed="false" styleClass="text-sm, text-destructive"/>
            
            <TLTextField fx:id="usernameField" label="" promptText=""/>
            <VBox spacing="4">
                <TLPasswordField fx:id="passwordField" label="" promptText=""/>
                <HBox alignment="CENTER_RIGHT">
                    <TLButton fx:id="forgotPasswordLink" text="" variant="GHOST"
                              styleClass="forgot-link"
                              onAction="#openForgotPassword"/>
                </HBox>
            </VBox>
            
            <TLButton fx:id="loginBtn" text="" variant="PRIMARY" maxWidth="Infinity" onAction="#handleLogin"/>
            <TLButton fx:id="biometricBtn" text="" variant="OUTLINE" maxWidth="Infinity" onAction="#handleBiometricLogin"/>
            
            <HBox alignment="CENTER">
                <Label fx:id="orContinueLabel" text="" styleClass="text-xs, text-muted"/>
            </HBox>
            
            <HBox alignment="CENTER" spacing="4">
                <Label fx:id="noAccountLabel" text="" styleClass="text-muted"/>
                <TLButton fx:id="registerLink" text="" variant="GHOST" styleClass="link-inline" onAction="#openRegister"/>
            </HBox>
        </VBox>
    </StackPane>

</HBox>
