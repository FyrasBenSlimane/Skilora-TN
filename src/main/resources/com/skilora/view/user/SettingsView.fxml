<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.String?>
<?import javafx.collections.FXCollections?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import com.skilora.framework.components.TLSwitch?>
<?import com.skilora.framework.components.TLSeparator?>
<?import com.skilora.framework.components.TLButton?>
<?import com.skilora.framework.components.TLSelect?>

<VBox xmlns:fx="http://javafx.com/fxml/1" 
      fx:controller="com.skilora.user.controller.SettingsController"
      spacing="24" fillWidth="true">
    
    <padding>
        <Insets top="32" right="32" bottom="32" left="32"/>
    </padding>

    <VBox spacing="8">
        <Label fx:id="settingsTitleLabel" text="" styleClass="h2"/>
        <Label fx:id="settingsSubtitleLabel" text="" styleClass="text-muted"/>
    </VBox>

    <VBox spacing="16" styleClass="card" style="-fx-padding: 24;">
        <Label fx:id="appearanceLabel" text="" styleClass="h3"/>
        <TLSeparator/>
        <HBox spacing="12" alignment="CENTER_LEFT">
            <Label fx:id="darkModeLabel" text="" minWidth="200"/>
            <TLSwitch fx:id="darkModeCheckbox"/>
        </HBox>
        <HBox spacing="12" alignment="CENTER_LEFT">
            <Label fx:id="animationsLabel" text="" minWidth="200"/>
            <TLSwitch fx:id="animationsCheckbox"/>
        </HBox>
    </VBox>

    <VBox spacing="16" styleClass="card" style="-fx-padding: 24;">
        <Label fx:id="notificationsLabel" text="" styleClass="h3"/>
        <TLSeparator/>
        <HBox spacing="12" alignment="CENTER_LEFT">
            <Label fx:id="enableNotificationsLabel" text="" minWidth="200"/>
            <TLSwitch fx:id="notificationsCheckbox"/>
        </HBox>
        <HBox spacing="12" alignment="CENTER_LEFT">
            <Label fx:id="soundNotificationsLabel" text="" minWidth="200"/>
            <TLSwitch fx:id="soundNotificationsCheckbox"/>
        </HBox>
        <HBox spacing="12" alignment="CENTER_LEFT">
            <Label fx:id="emailNotificationsLabel" text="" minWidth="200"/>
            <TLSwitch fx:id="emailNotificationsCheckbox"/>
        </HBox>
    </VBox>

    <VBox spacing="16" styleClass="card" style="-fx-padding: 24;">
        <Label fx:id="languageSectionLabel" text="" styleClass="h3"/>
        <TLSeparator/>
        <HBox spacing="12" alignment="CENTER_LEFT">
            <Label fx:id="languageLabel" text="" minWidth="200"/>
            <TLSelect fx:id="languageComboBox" minWidth="200"/>
        </HBox>
    </VBox>

    <VBox spacing="16" styleClass="card" style="-fx-padding: 24;">
        <Label fx:id="securitySectionLabel" text="" styleClass="h3"/>
        <TLSeparator/>
        <HBox spacing="12" alignment="CENTER_LEFT">
            <Label fx:id="changePasswordLabel" text="" minWidth="200"/>
            <TLButton fx:id="changePasswordBtn" text="" variant="OUTLINE" onAction="#handleChangePassword"/>
        </HBox>
        <TLSeparator/>
        <!-- Two-Factor Authentication Section -->
        <VBox spacing="8">
            <HBox spacing="12" alignment="CENTER_LEFT">
                <Label fx:id="twoFactorAuthLabel" text="Two-Factor Authentication" minWidth="200"/>
                <TLSwitch fx:id="twoFactorAuthSwitch"/>
            </HBox>
            <Label fx:id="twoFactorAuthStatusLabel" text="" styleClass="text-sm"/>
            <Label fx:id="twoFactorAuthDescription" text="Add an extra layer of security to your account" styleClass="text-sm, text-muted" wrapText="true"/>
        </VBox>
    </VBox>

    <VBox spacing="16" styleClass="card" style="-fx-padding: 24;">
        <Label fx:id="advancedPrefsLabel" text="" styleClass="h3"/>
        <TLSeparator/>
        <HBox spacing="12" alignment="CENTER_LEFT">
            <Label fx:id="currencyPrefLabel" text="" minWidth="200"/>
            <TLButton fx:id="currencyBtn" text="" variant="OUTLINE" onAction="#handleCurrencyPreference"/>
        </HBox>
        <HBox spacing="12" alignment="CENTER_LEFT">
            <Label fx:id="trainerUpgradeLabel" text="" minWidth="200"/>
            <TLButton fx:id="trainerUpgradeBtn" text="" variant="OUTLINE" onAction="#handleRequestTrainerUpgrade"/>
        </HBox>
    </VBox>

    <VBox spacing="16" styleClass="card" style="-fx-padding: 24;">
        <Label fx:id="dangerZoneLabel" text="" styleClass="h3"/>
        <TLSeparator/>
        <HBox spacing="12" alignment="CENTER_LEFT">
            <Label fx:id="deleteAccountLabel" text="" minWidth="200"/>
            <TLButton fx:id="deleteAccountBtn" text="" variant="DANGER" onAction="#handleDeleteAccount"/>
        </HBox>
    </VBox>

    <HBox spacing="12" alignment="CENTER_RIGHT">
        <TLButton fx:id="saveBtn" text="" variant="PRIMARY"/>
        <TLButton fx:id="cancelBtn" text="" variant="OUTLINE"/>
    </HBox>

</VBox>
