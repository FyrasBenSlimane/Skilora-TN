<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>
<?import com.skilora.framework.components.*?>
<?import com.skilora.framework.components.TLSeparator?>

<VBox xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.skilora.user.controller.ForgotPasswordController"
      spacing="24"
      alignment="CENTER"
      styleClass="transparent-bg">
    
    <padding><Insets top="48" right="32" bottom="48" left="32"/></padding>
    
    <TLCard maxWidth="480" alignment="CENTER">
        <VBox spacing="0" alignment="CENTER">
            <padding><Insets top="36" right="40" bottom="36" left="40"/></padding>
            
            <HBox fx:id="stepIndicator" spacing="0" alignment="CENTER" styleClass="step-indicator">
                <VBox alignment="CENTER" spacing="4">
                    <StackPane fx:id="step1Circle" minWidth="32" minHeight="32" maxWidth="32" maxHeight="32"
                               styleClass="step-circle-active">
                        <Label fx:id="step1Label" text="1" styleClass="step-number-active"/>
                    </StackPane>
                    <Label fx:id="step1Text" text="" styleClass="step-text-active"/>
                </VBox>
                <Region fx:id="connector1" prefWidth="60" prefHeight="2" maxHeight="2"
                        styleClass="step-connector" VBox.vgrow="NEVER"/>
                <VBox alignment="CENTER" spacing="4">
                    <StackPane fx:id="step2Circle" minWidth="32" minHeight="32" maxWidth="32" maxHeight="32"
                               styleClass="step-circle-inactive">
                        <Label fx:id="step2Label" text="2" styleClass="step-number-inactive"/>
                    </StackPane>
                    <Label fx:id="step2Text" text="" styleClass="step-text-inactive"/>
                </VBox>
                <Region fx:id="connector2" prefWidth="60" prefHeight="2" maxHeight="2"
                        styleClass="step-connector" VBox.vgrow="NEVER"/>
                <VBox alignment="CENTER" spacing="4">
                    <StackPane fx:id="step3Circle" minWidth="32" minHeight="32" maxWidth="32" maxHeight="32"
                               styleClass="step-circle-inactive">
                        <Label fx:id="step3Label" text="3" styleClass="step-number-inactive"/>
                    </StackPane>
                    <Label fx:id="step3Text" text="" styleClass="step-text-inactive"/>
                </VBox>
            </HBox>
            
            <VBox spacing="6" alignment="CENTER" styleClass="forgot-header">
                <Label fx:id="iconLabel" text="" styleClass="forgot-icon"/>
                <Label fx:id="titleLabel" text="" styleClass="h2"/>
                <Label fx:id="subtitleLabel" text="" 
                       styleClass="text-muted" wrapText="true" alignment="CENTER"
                       style="-fx-max-width: 320;"/>
            </VBox>
            
            <VBox fx:id="contentArea" spacing="16" alignment="CENTER" style="-fx-min-width: 380;">
                <VBox fx:id="emailContainer" spacing="8">
                    <Label fx:id="fieldLabel" text="" styleClass="label"/>
                    <TLTextField fx:id="emailField" promptText="" prefWidth="380"/>
                </VBox>
                
                <VBox fx:id="otpContainer" spacing="8" visible="false" managed="false" alignment="CENTER">
                    <Label fx:id="otpFieldLabel" text="" styleClass="label, items-center" alignment="CENTER"/>
                    <TLOtpInput fx:id="otpInput"/>
                </VBox>
                
                <VBox fx:id="passwordContainer" spacing="8" visible="false" managed="false">
                    <TLPasswordField fx:id="newPasswordField" label="" promptText=""/>
                    <TLPasswordField fx:id="confirmPasswordField" label="" promptText=""/>
                </VBox>
                
                <Label fx:id="errorLabel" text="" styleClass="text-destructive, pt-4" visible="false" managed="false"
                       wrapText="true"/>
                <Label fx:id="successLabel" text="" styleClass="text-success, pt-4" 
                       visible="false" managed="false" wrapText="true"/>
                
                <HBox fx:id="loadingBox" spacing="8" alignment="CENTER" visible="false" managed="false"
                      styleClass="pt-8">
                    <TLSpinner fx:id="loadingSpinner"/>
                    <Label fx:id="loadingLabel" text="" styleClass="text-muted, text-sm"/>
                </HBox>
            </VBox>
            
            <VBox spacing="10" styleClass="pt-20">
                <TLButton fx:id="sendBtn" text="" variant="PRIMARY" 
                         onAction="#handleSendReset" maxWidth="Infinity"/>
                <TLButton fx:id="backBtn" text="" variant="GHOST" 
                         onAction="#handleBack" maxWidth="Infinity"
                         styleClass="text-sm"/>
            </VBox>
            
            <VBox fx:id="resendSection" spacing="8" alignment="CENTER" styleClass="pt-16"
                  visible="false" managed="false">
                <TLSeparator/>
                <HBox spacing="8" alignment="CENTER" styleClass="pt-8">
                    <Label fx:id="notReceivedLabel" text="" styleClass="text-muted, text-sm"/>
                    <TLButton fx:id="resendBtn" text="" variant="OUTLINE" size="SM"
                             onAction="#handleResend" disable="true"/>
                </HBox>
            </VBox>
        </VBox>
    </TLCard>
</VBox>
