<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.chart.PieChart?>
<?import javafx.scene.chart.BarChart?>
<?import javafx.scene.chart.CategoryAxis?>
<?import javafx.scene.chart.NumberAxis?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Separator?>

<VBox spacing="25" xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.skilora.support.controller.StatisticsController"
      style="-fx-padding: 30;">
    <children>
        <!-- Header -->
        <HBox alignment="CENTER_LEFT" spacing="10">
            <Label text="Support Statistics" styleClass="section-title"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="Refresh" onAction="#handleRefresh" styleClass="btn-secondary"/>
        </HBox>
        <Separator/>

        <!-- Summary Row -->
        <HBox spacing="20" alignment="CENTER">
            <VBox alignment="CENTER"
                  style="-fx-background-color: -fx-base-surface; -fx-padding: 20; -fx-background-radius: 12; -fx-border-color: -fx-base-border; -fx-border-radius: 12;"
                  prefWidth="180">
                <Label text="Total Tickets" style="-fx-text-fill: -fx-base-text-muted; -fx-font-size: 12px;"/>
                <Label fx:id="totalLabel" text="0" style="-fx-font-size: 28px; -fx-font-weight: bold;"/>
            </VBox>
            <VBox alignment="CENTER"
                  style="-fx-background-color: -fx-base-surface; -fx-padding: 20; -fx-background-radius: 12; -fx-border-color: #22C55E; -fx-border-radius: 12;"
                  prefWidth="180">
                <Label text="Resolved" style="-fx-text-fill: #22C55E; -fx-font-size: 12px;"/>
                <Label fx:id="resolvedLabel" text="0" style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #22C55E;"/>
            </VBox>
            <VBox alignment="CENTER"
                  style="-fx-background-color: -fx-base-surface; -fx-padding: 20; -fx-background-radius: 12; -fx-border-color: #EF4444; -fx-border-radius: 12;"
                  prefWidth="180">
                <Label text="Open" style="-fx-text-fill: #EF4444; -fx-font-size: 12px;"/>
                <Label fx:id="openLabel" text="0" style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #EF4444;"/>
            </VBox>
        </HBox>

        <Separator/>

        <!-- Charts -->
        <HBox spacing="30" VBox.vgrow="ALWAYS">
            <VBox spacing="10" HBox.hgrow="ALWAYS">
                <Label text="Status Distribution"
                       style="-fx-font-weight: bold; -fx-text-fill: -fx-base-text;"/>
                <PieChart fx:id="statusChart" legendVisible="true"
                          prefHeight="300" prefWidth="350"/>
            </VBox>
            <VBox spacing="10" HBox.hgrow="ALWAYS">
                <Label text="Priority Distribution"
                       style="-fx-font-weight: bold; -fx-text-fill: -fx-base-text;"/>
                <BarChart fx:id="priorityChart" legendVisible="false"
                          prefHeight="300" prefWidth="350">
                    <xAxis>
                        <CategoryAxis label="Priority"/>
                    </xAxis>
                    <yAxis>
                        <NumberAxis label="Count"/>
                    </yAxis>
                </BarChart>
            </VBox>
        </HBox>
    </children>
</VBox>
