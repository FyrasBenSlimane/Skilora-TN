<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Tooltip?>

<VBox spacing="10" xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.skilora.support.controller.TicketCardController"
      style="-fx-background-color: -fx-base-surface; -fx-padding: 15; -fx-background-radius: 12; -fx-border-color: -fx-base-border; -fx-border-radius: 12; -fx-cursor: hand;"
      onMouseClicked="#handleCardClick">
    <children>
        <!-- Row 1: Subject + Status -->
        <HBox alignment="CENTER_LEFT" spacing="10">
            <Label fx:id="subjectLabel" text="Subject" styleClass="ticket-card-title"
                   wrapText="true" maxWidth="240"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="statusBadge" text="OPEN" styleClass="badge"/>
        </HBox>

        <!-- Row 2: Description preview -->
        <Label fx:id="descriptionPreview" text="Description preview..."
               style="-fx-text-fill: -fx-base-text-muted; -fx-font-size: 12px;"
               wrapText="true" maxHeight="36"/>

        <!-- Row 3: Priority + Category -->
        <HBox alignment="CENTER_LEFT" spacing="10">
            <Label fx:id="priorityLabel" text="HIGH"
                   style="-fx-font-weight: bold; -fx-font-size: 11px;"/>
            <Label text="•" style="-fx-text-fill: -fx-base-text-muted;"/>
            <Label fx:id="categoryLabel" text="Technical"
                   style="-fx-text-fill: -fx-base-text-muted; -fx-font-size: 11px;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="dateLabel" text="2024-01-01"
                   style="-fx-text-fill: -fx-base-text-muted; -fx-font-size: 11px;"/>
        </HBox>

        <!-- Row 4: Actions -->
        <HBox alignment="CENTER_RIGHT" spacing="8">
            <Button text="Rate" onAction="#handleLeaveFeedback" styleClass="btn-secondary"
                    style="-fx-font-size: 11px; -fx-padding: 3 12;">
                <tooltip>
                    <Tooltip text="Leave feedback"/>
                </tooltip>
            </Button>
            <Button text="Edit" onAction="#handleEdit" styleClass="btn-secondary"
                    style="-fx-font-size: 11px; -fx-padding: 3 12;"/>
            <Button text="Delete" onAction="#handleDelete"
                    style="-fx-background-color: #EF4444; -fx-text-fill: white; -fx-font-size: 11px; -fx-padding: 3 12;"/>
        </HBox>
    </children>
</VBox>
