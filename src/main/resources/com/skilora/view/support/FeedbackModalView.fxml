<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Separator?>
<?import org.controlsfx.control.Rating?>

<VBox spacing="20" xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.skilora.support.controller.FeedbackModalController"
      style="-fx-background-color: -fx-base-surface; -fx-padding: 30; -fx-background-radius: 16; -fx-border-color: -fx-base-border; -fx-border-radius: 16;"
      prefWidth="460">
    <children>
        <!-- Header -->
        <HBox alignment="CENTER_LEFT">
            <Label text="Leave Feedback" styleClass="section-title"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="✕" onAction="#handleClose"
                    style="-fx-background-color: transparent; -fx-text-fill: -fx-base-text-muted; -fx-font-size: 18px; -fx-cursor: hand;"/>
        </HBox>
        <Separator/>

        <!-- Rating -->
        <VBox spacing="8" alignment="CENTER">
            <Label text="How was your experience?"
                   style="-fx-font-size: 15px; -fx-text-fill: -fx-base-text;"/>
            <Rating fx:id="ratingControl" max="5"/>
        </VBox>

        <Separator/>

        <!-- Comment + Sentiment -->
        <VBox spacing="5">
            <HBox alignment="CENTER_LEFT" spacing="10">
                <Label text="Comment" styleClass="label"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Label fx:id="sentimentLabel" text=""
                       style="-fx-font-size: 12px; -fx-font-style: italic;"/>
            </HBox>
            <TextArea fx:id="commentArea" promptText="Share your thoughts…"
                      prefRowCount="4" wrapText="true"/>
        </VBox>

        <Separator/>

        <!-- Actions -->
        <HBox spacing="10" alignment="CENTER_RIGHT">
            <Button text="Cancel" onAction="#handleClose" styleClass="btn-secondary"/>
            <Button text="Submit Feedback" onAction="#handleSubmit" styleClass="btn-primary"/>
        </HBox>
    </children>
</VBox>
