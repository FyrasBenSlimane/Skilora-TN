<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>
<?import com.skilora.framework.components.*?>

<VBox xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.skilora.recruitment.controller.PostJobController"
      spacing="24"
      styleClass="transparent-bg">
    <padding><Insets top="32" right="32" bottom="32" left="32"/></padding>
    
    <HBox spacing="24" alignment="CENTER_LEFT">
        <VBox spacing="4">
            <Label text="" styleClass="h2"/>
            <Label fx:id="stepLabel" text="" styleClass="text-muted"/>
        </VBox>
        <Region HBox.hgrow="ALWAYS"/>
        <TLButton fx:id="saveBtn" text="" variant="OUTLINE" onAction="#handleSaveDraft"/>
    </HBox>
    
    <HBox spacing="8" alignment="CENTER">
        <VBox fx:id="step1Indicator" spacing="4" alignment="CENTER" HBox.hgrow="ALWAYS">
            <Label text="" styleClass="text-muted"/>
            <TLProgress fx:id="progress1" progress="1.0" maxWidth="Infinity"/>
        </VBox>
        <VBox fx:id="step2Indicator" spacing="4" alignment="CENTER" HBox.hgrow="ALWAYS">
            <Label text="" styleClass="text-muted"/>
            <TLProgress fx:id="progress2" progress="0.0" maxWidth="Infinity"/>
        </VBox>
        <VBox fx:id="step3Indicator" spacing="4" alignment="CENTER" HBox.hgrow="ALWAYS">
            <Label text="" styleClass="text-muted"/>
            <TLProgress fx:id="progress3" progress="0.0" maxWidth="Infinity"/>
        </VBox>
    </HBox>
    
    <ScrollPane fitToWidth="true" styleClass="transparent-bg" VBox.vgrow="ALWAYS">
        <StackPane fx:id="contentStack"/>
    </ScrollPane>
    
    <HBox spacing="12" alignment="CENTER_RIGHT">
        <TLButton fx:id="cancelBtn" text="" variant="GHOST" onAction="#handleCancel"/>
        <Region HBox.hgrow="ALWAYS"/>
        <TLButton fx:id="prevBtn" text="" variant="OUTLINE" onAction="#handlePrevious" visible="false"/>
        <TLButton fx:id="nextBtn" text="" variant="PRIMARY" onAction="#handleNext"/>
        <TLButton fx:id="publishBtn" text="" variant="PRIMARY" onAction="#handlePublish" visible="false"/>
    </HBox>
</VBox>
