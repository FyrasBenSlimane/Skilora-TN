<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.*?>
<?import com.skilora.framework.components.TLButton?>
<?import com.skilora.framework.components.TLProgress?>

<VBox xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.skilora.recruitment.controller.PostJobController"
      styleClass="page-container" spacing="20">
    <padding><Insets top="24" right="24" bottom="24" left="24"/></padding>

    <!-- Top Wizard Progress Card -->
    <VBox spacing="16" styleClass="card" style="-fx-padding: 24;">
        <HBox spacing="16" alignment="CENTER_LEFT">
            <VBox fx:id="step1Indicator" spacing="4" styleClass="step-indicator"/>
            <TLProgress fx:id="progress1" prefWidth="80" progress="0.33"/>
            <VBox fx:id="step2Indicator" spacing="4" styleClass="step-indicator"/>
            <TLProgress fx:id="progress2" prefWidth="80" progress="0"/>
            <VBox fx:id="step3Indicator" spacing="4" styleClass="step-indicator"/>
            <TLProgress fx:id="progress3" prefWidth="80" progress="0"/>
            <Region HBox.hgrow="ALWAYS" />
            <Label fx:id="stepLabel" styleClass="h3, text-muted"/>
        </HBox>
    </VBox>

    <!-- Main Content Area Card -->
    <VBox spacing="16" styleClass="card" style="-fx-padding: 32;" VBox.vgrow="ALWAYS">
        <StackPane fx:id="contentStack" VBox.vgrow="ALWAYS" minHeight="400"/>
        
        <Separator style="-fx-padding: 16 0 16 0;"/>
        
        <HBox spacing="12" alignment="CENTER_RIGHT">
            <TLButton fx:id="cancelBtn"  text="Annuler"    variant="OUTLINE" onAction="#handleCancel"/>
            <Region HBox.hgrow="ALWAYS" />
            <TLButton fx:id="saveBtn"    text="Enregistrer" variant="OUTLINE" onAction="#handleSaveDraft" visible="false" managed="false"/>
            <TLButton fx:id="prevBtn"    text="Précédent"  variant="OUTLINE" onAction="#handlePrevious"/>
            <TLButton fx:id="nextBtn"    text="Suivant"    variant="PRIMARY" onAction="#handleNext"/>
            <TLButton fx:id="publishBtn" text="Publier"    variant="PRIMARY" onAction="#handlePublish"/>
        </HBox>
    </VBox>
</VBox>
