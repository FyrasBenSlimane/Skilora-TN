<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>
<?import com.skilora.framework.components.*?>

<VBox xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.skilora.controller.recruitment.ApplicationsController"
      spacing="24"
      style="-fx-background-color: transparent;">
    <padding><Insets top="32" right="32" bottom="32" left="32"/></padding>
    
    <!-- Header -->
    <HBox spacing="24" alignment="CENTER_LEFT">
        <VBox spacing="4">
            <Label text="Mes Candidatures" styleClass="h2"/>
            <Label fx:id="statsLabel" text="0 candidatures en cours" styleClass="text-muted"/>
        </VBox>
        
        <Region HBox.hgrow="ALWAYS"/>
        
        <TLButton fx:id="refreshBtn" text="🔄 Actualiser" variant="GHOST" onAction="#handleRefresh"/>
    </HBox>
    
    <!-- Simple List View -->
    <ScrollPane fitToWidth="true" style="-fx-background-color: transparent;" VBox.vgrow="ALWAYS">
        <VBox fx:id="applicationsList" spacing="0" style="-fx-background-color: transparent;"/>
    </ScrollPane>
</VBox>
