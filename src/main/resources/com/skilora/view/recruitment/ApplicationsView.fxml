<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>
<?import com.skilora.framework.components.*?>
<?import com.skilora.framework.components.TLSeparator?>

<VBox xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.skilora.recruitment.controller.ApplicationsController"
      spacing="24"
      styleClass="transparent-bg">
    <padding><Insets top="32" right="32" bottom="32" left="32"/></padding>
    
    <!-- Header -->
    <HBox spacing="24" alignment="CENTER_LEFT">
        <VBox spacing="4">
            <Label text="" styleClass="h2"/>
            <Label fx:id="statsLabel" text="" styleClass="text-muted"/>
        </VBox>
        
        <Region HBox.hgrow="ALWAYS"/>
        
        <TLButton fx:id="refreshBtn" text="" variant="GHOST" onAction="#handleRefresh"/>
    </HBox>
    
    <!-- Kanban Board -->
    <HBox spacing="16" VBox.vgrow="ALWAYS">
        <!-- Applied Column -->
        <VBox spacing="12" styleClass="kanban-column, kanban-col-applied" HBox.hgrow="ALWAYS">
            <HBox spacing="8" alignment="CENTER_LEFT">
                <Label fx:id="appliedHeader" text="" styleClass="h4"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Label fx:id="appliedCount" text="0" styleClass="badge"/>
            </HBox>
            <TLSeparator/>
            <ScrollPane fitToWidth="true" styleClass="transparent-bg" VBox.vgrow="ALWAYS">
                <VBox fx:id="appliedColumn" spacing="12"/>
            </ScrollPane>
        </VBox>
        
        <!-- Under Review Column -->
        <VBox spacing="12" styleClass="kanban-column, kanban-col-review" HBox.hgrow="ALWAYS">
            <HBox spacing="8" alignment="CENTER_LEFT">
                <Label fx:id="reviewingHeader" text="" styleClass="h4"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Label fx:id="reviewingCount" text="0" styleClass="badge"/>
            </HBox>
            <TLSeparator/>
            <ScrollPane fitToWidth="true" styleClass="transparent-bg" VBox.vgrow="ALWAYS">
                <VBox fx:id="reviewingColumn" spacing="12"/>
            </ScrollPane>
        </VBox>
        
        <!-- Interviewing Column -->
        <VBox spacing="12" styleClass="kanban-column, kanban-col-interview" HBox.hgrow="ALWAYS">
            <HBox spacing="8" alignment="CENTER_LEFT">
                <Label fx:id="interviewingHeader" text="" styleClass="h4"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Label fx:id="interviewingCount" text="0" styleClass="badge"/>
            </HBox>
            <TLSeparator/>
            <ScrollPane fitToWidth="true" styleClass="transparent-bg" VBox.vgrow="ALWAYS">
                <VBox fx:id="interviewingColumn" spacing="12"/>
            </ScrollPane>
        </VBox>
        
        <!-- Offer Column -->
        <VBox spacing="12" styleClass="kanban-column, kanban-col-offer" HBox.hgrow="ALWAYS">
            <HBox spacing="8" alignment="CENTER_LEFT">
                <Label fx:id="offerHeader" text="" styleClass="h4"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Label fx:id="offerCount" text="0" styleClass="badge"/>
            </HBox>
            <TLSeparator/>
            <ScrollPane fitToWidth="true" styleClass="transparent-bg" VBox.vgrow="ALWAYS">
                <VBox fx:id="offerColumn" spacing="12"/>
            </ScrollPane>
        </VBox>
    </HBox>
</VBox>
