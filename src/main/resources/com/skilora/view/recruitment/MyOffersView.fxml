<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>
<?import com.skilora.framework.components.*?>

<VBox xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.skilora.recruitment.controller.MyOffersController"
      spacing="24"
      styleClass="transparent-bg">
    <padding><Insets top="32" right="32" bottom="32" left="32"/></padding>

    <HBox spacing="16" alignment="CENTER_LEFT">
        <VBox spacing="4">
            <Label text="" styleClass="h2"/>
            <Label fx:id="statsLabel" text="" styleClass="text-muted"/>
        </VBox>
        <Region HBox.hgrow="ALWAYS"/>
        <TLButton fx:id="newOfferBtn" text="" variant="PRIMARY" onAction="#handleNewOffer"/>
        <TLButton fx:id="refreshBtn" text="" variant="OUTLINE" onAction="#handleRefresh"/>
    </HBox>

    <HBox fx:id="filterBox" spacing="8" alignment="CENTER_LEFT"/>

    <TLTextField fx:id="searchField" promptText="" prefWidth="400"/>

    <VBox fx:id="offersContainer" spacing="12"/>

    <VBox fx:id="emptyState" spacing="12" alignment="CENTER" visible="false" managed="false"
          styleClass="p-48"/>
</VBox>
