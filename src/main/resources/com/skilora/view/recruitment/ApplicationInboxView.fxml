<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>
<?import com.skilora.framework.components.*?>

<VBox xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.skilora.recruitment.controller.ApplicationInboxController"
      spacing="24"
      styleClass="transparent-bg">
    <padding><Insets top="32" right="32" bottom="32" left="32"/></padding>
    
    <HBox spacing="24" alignment="CENTER_LEFT">
        <VBox spacing="4">
            <Label text="" styleClass="h2"/>
            <Label fx:id="statsLabel" text="" styleClass="text-muted"/>
        </VBox>
        <Region HBox.hgrow="ALWAYS"/>
        <HBox spacing="12">
            <TLButton fx:id="filterBtn" text="" variant="OUTLINE" onAction="#handleFilter"/>
            <TLButton fx:id="refreshBtn" text="" variant="GHOST" onAction="#handleRefresh"/>
        </HBox>
    </HBox>
    
    <HBox fx:id="filterBar" spacing="12" alignment="CENTER_LEFT" managed="false" visible="false">
        <Label text="" styleClass="text-muted"/>
        <TLSelect fx:id="jobSelect" promptText=""/>
        <Label text="" styleClass="text-muted"/>
        <TLSelect fx:id="statusSelect" promptText=""/>
        <Region HBox.hgrow="ALWAYS"/>
        <TLButton text="" variant="GHOST" onAction="#handleResetFilters"/>
    </HBox>
    
    <TLTable fx:id="applicationsTable" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="candidateCol" text="" prefWidth="180"/>
            <TableColumn fx:id="jobCol" text="" prefWidth="170"/>
            <TableColumn fx:id="dateCol" text="" prefWidth="100"/>
            <TableColumn fx:id="matchCol" text="" prefWidth="90"/>
            <TableColumn fx:id="scoreCol" text="" prefWidth="90"/>
            <TableColumn fx:id="statusCol" text="" prefWidth="120"/>
            <TableColumn fx:id="actionsCol" text="" prefWidth="80"/>
        </columns>
    </TLTable>
    
    <HBox spacing="12" alignment="CENTER">
        <Label fx:id="paginationLabel" text="" styleClass="text-muted"/>
        <Region HBox.hgrow="ALWAYS"/>
        <TLButton fx:id="prevBtn" text="" variant="OUTLINE" onAction="#handlePrevPage"/>
        <Label fx:id="pageLabel" text="" styleClass="text-muted"/>
        <TLButton fx:id="nextBtn" text="" variant="OUTLINE" onAction="#handleNextPage"/>
    </HBox>
</VBox>
