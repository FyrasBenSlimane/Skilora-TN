<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import com.skilora.framework.components.TLButton?>
<?import com.skilora.framework.components.TLTextField?>

<VBox xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.skilora.recruitment.controller.FeedController"
      styleClass="page-container" spacing="16">
    <padding><Insets top="24" right="24" bottom="24" left="24"/></padding>
    <HBox spacing="12" alignment="CENTER_LEFT">
        <TLTextField fx:id="searchField" promptText="Rechercher une offre..." prefWidth="300"/>
        <Region HBox.hgrow="ALWAYS"/>
        <TLButton fx:id="refreshBtn" text="Actualiser" onAction="#handleRefresh"/>
    </HBox>
    <FlowPane fx:id="tabsBox" hgap="8" vgap="8"/>
    <ListView fx:id="jobList" styleClass="feed-job-list" VBox.vgrow="ALWAYS"/>
</VBox>
