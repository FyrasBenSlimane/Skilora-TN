<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>
<?import com.skilora.framework.components.*?>
<?import com.skilora.framework.components.TLSeparator?>

<VBox xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.skilora.recruitment.controller.JobDetailsController"
      spacing="24"
      styleClass="transparent-bg">
    <padding><Insets top="32" right="32" bottom="32" left="32"/></padding>
    
    <HBox spacing="12" alignment="CENTER_LEFT">
        <TLButton fx:id="backBtn" text="" variant="GHOST" onAction="#handleBack"/>
    </HBox>
    
    <HBox spacing="24" alignment="TOP_LEFT">
        <VBox alignment="CENTER" styleClass="bg-muted-rounded">
            <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>
            <Label fx:id="companyInitials" text="" styleClass="h2"/>
        </VBox>
        
        <VBox spacing="8" HBox.hgrow="ALWAYS">
            <Label fx:id="jobTitle" text="" styleClass="h2"/>
            <Label fx:id="companyName" text="" styleClass="h4"/>
            <HBox spacing="12">
                <Label fx:id="jobLocation" text="" styleClass="text-muted"/>
                <Label fx:id="jobType" text="" styleClass="text-muted"/>
                <Label fx:id="postedDate" text="" styleClass="text-muted"/>
            </HBox>
        </VBox>
        
        <VBox spacing="12" alignment="TOP_RIGHT">
            <TLButton fx:id="applyBtn" text="" variant="PRIMARY" onAction="#handleApply"/>
            <TLButton fx:id="saveBtn" text="" variant="OUTLINE" onAction="#handleSave"/>
        </VBox>
    </HBox>
    
    <TLSeparator/>
    
    <ScrollPane fitToWidth="true" styleClass="transparent-bg" VBox.vgrow="ALWAYS">
        <VBox spacing="24">
            <padding><Insets top="0" right="16" bottom="0" left="0"/></padding>
            
            <VBox spacing="12">
                <Label fx:id="descriptionHeader" text="" styleClass="h3"/>
                <Label fx:id="jobDescription" wrapText="true" styleClass="text-muted" text=""/>
            </VBox>
            
            <VBox spacing="12">
                <Label fx:id="skillsHeader" text="" styleClass="h3"/>
                <FlowPane fx:id="skillsContainer" hgap="8" vgap="8"/>
            </VBox>
            
            <VBox spacing="12">
                <Label fx:id="salaryHeader" text="" styleClass="h3"/>
                <Label fx:id="salaryRange" text="" styleClass="h4"/>
            </VBox>
            
            <VBox spacing="12">
                <Label fx:id="benefitsHeader" text="" styleClass="h3"/>
                <VBox fx:id="benefitsList" spacing="8"/>
            </VBox>
            
            <!-- AI Insights -->
            <VBox spacing="8">
                <HBox spacing="16">
                    <Label fx:id="matchScoreLabel" styleClass="text-muted" text="Match: -"/>
                    <Label fx:id="candidateScoreLabel" styleClass="text-muted" text="Score candidat: -"/>
                </HBox>
                <Label fx:id="recommendationLabel" wrapText="true" styleClass="text-muted" text="Recommandations: -"/>
            </VBox>

            <VBox spacing="12">
                <Label fx:id="statsHeader" text="" styleClass="h3"/>
                <HBox spacing="24">
                    <VBox spacing="4">
                        <Label fx:id="applicantCount" text="0" styleClass="h3"/>
                        <Label fx:id="applicantCountLabel" text="" styleClass="text-muted"/>
                    </VBox>
                    <VBox spacing="4">
                        <Label fx:id="viewCount" text="0" styleClass="h3"/>
                        <Label fx:id="viewCountLabel" text="" styleClass="text-muted"/>
                    </VBox>
                </HBox>
            </VBox>
        </VBox>
    </ScrollPane>
</VBox>
