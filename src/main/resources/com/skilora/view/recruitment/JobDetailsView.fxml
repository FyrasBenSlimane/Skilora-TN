<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.*?>
<?import com.skilora.framework.components.TLButton?>

<ScrollPane xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.skilora.recruitment.controller.JobDetailsController" fitToWidth="true" style="-fx-background-color: transparent; -fx-padding: 0;">
    <VBox styleClass="page-container" spacing="16">
        <padding><Insets top="24" right="24" bottom="24" left="24"/></padding>
        <!-- Back button -->
        <HBox spacing="12" alignment="CENTER_LEFT">
            <TLButton fx:id="backBtn" text="← Retour" variant="OUTLINE" onAction="#handleBack"/>
        </HBox>

        <VBox spacing="16" styleClass="card" style="-fx-padding: 24;">
            <!-- Header -->
            <HBox spacing="16" alignment="CENTER_LEFT">
                <Label fx:id="companyInitials" styleClass="h2" minWidth="64" minHeight="64"
                       style="-fx-background-color:-fx-primary; -fx-text-fill: white; -fx-background-radius:8; -fx-alignment:center;"/>
                <VBox spacing="4">
                    <Label fx:id="jobTitle" styleClass="page-title" wrapText="true"/>
                    <Label fx:id="companyName" styleClass="text-muted, h3"/>
                </VBox>
            </HBox>
            <!-- Meta row -->
            <FlowPane hgap="24" vgap="12">
                <Label fx:id="jobLocation" styleClass="badge, badge-outline"/>
                <Label fx:id="jobType" styleClass="badge, badge-outline"/>
                <Label fx:id="postedDate" styleClass="text-muted"/>
                <Label fx:id="salaryRange" styleClass="text-muted"/>
            </FlowPane>
        </VBox>

        <VBox spacing="16" styleClass="card" style="-fx-padding: 24;">
            <!-- AI insights -->
            <HBox spacing="16">
                <Label fx:id="matchScoreLabel" styleClass="badge, badge-info"/>
                <Label fx:id="candidateScoreLabel" styleClass="badge, badge-warning"/>
                <Label fx:id="applicantCount" styleClass="text-muted"/>
                <Label fx:id="viewCount" styleClass="text-muted"/>
            </HBox>
            <Label fx:id="recommendationLabel" wrapText="true" visible="false" managed="false" styleClass="alert, alert-info"/>
        </VBox>

        <VBox spacing="16" styleClass="card" style="-fx-padding: 24;">
            <!-- Description -->
            <VBox spacing="8">
                <Label text="Description" styleClass="h3"/>
                <Label fx:id="jobDescription" wrapText="true" maxWidth="Infinity" style="-fx-font-size: 14px; -fx-line-spacing: 4px;"/>
            </VBox>
            
            <Separator style="-fx-padding: 8 0 8 0;"/>

            <!-- Skills -->
            <VBox spacing="8">
                <Label text="Compétences requises" styleClass="h3"/>
                <FlowPane fx:id="skillsContainer" hgap="8" vgap="8"/>
            </VBox>

            <!-- Benefits -->
            <VBox spacing="8">
                <Label text="Avantages" styleClass="h3"/>
                <VBox fx:id="benefitsList" spacing="4"/>
            </VBox>
        </VBox>

        <!-- Actions -->
        <VBox spacing="16" styleClass="card" style="-fx-padding: 24;">
            <HBox spacing="12" alignment="CENTER_RIGHT">
                <TLButton fx:id="saveBtn" text="Sauvegarder" variant="OUTLINE" onAction="#handleSave"/>
                <TLButton fx:id="applyBtn" text="Postuler" variant="PRIMARY" onAction="#handleApply"/>
            </HBox>
        </VBox>
    </VBox>
</ScrollPane>
