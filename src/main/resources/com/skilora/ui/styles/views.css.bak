/**
 * Skilora View-Specific Styles
 *
 * View-specific styles for login, job cards, dialog overrides,
 * notifications, and module-specific UI elements.
 */

/* ========== AUTH HERO ========== */
.auth-hero {
    -fx-background-color: linear-gradient(from 0% 0% to 100% 100%, -fx-auth-hero-from, -fx-auth-hero-to);
    -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.4), 10, 0, 0, 0);
}
.root.light .auth-hero {
    -fx-background-color: linear-gradient(from 0% 0% to 100% 100%, -fx-auth-hero-from, -fx-auth-hero-to);
    -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 10, 0, 0, 0);
}

/* ========== LOGIN VIEW ========== */
.login-card { -fx-background-color: transparent; -fx-effect: null; }
/* ========== NOTIFICATIONS ========== */
.notification-unread {
    -fx-border-color: -fx-primary;
    -fx-border-width: 0 0 0 3px;
}


/* Fix ID Column Alignment - MOVED TO END FOR SPECIFICITY */
.table-view .column-header.id-column {
    padding: 0 !important;
    -fx-padding: 0 !important; 
    text-align: center !important;
    -fx-alignment: center !important;
}
.table-view .column-header.id-column .label {
    text-align: center !important;
    -fx-alignment: center !important;
    padding: 0 !important;
    -fx-padding: 0 !important;
}
.table-view .table-cell.id-column {
    padding: 0 !important;
    -fx-padding: 0 !important;
    text-align: center !important;
    -fx-alignment: center !important;
}

/* Fix Check/Select Column Alignment */
.table-view .column-header.check-column {
    padding: 0 !important;
    -fx-padding: 0 !important;
    text-align: center !important;
    -fx-alignment: center !important;
}
.table-view .column-header.check-column .label {
    padding: 0 !important;
    -fx-padding: 0 !important;
}
.table-view .table-cell.check-column {
    padding: 0 !important;
    -fx-padding: 0 !important;
    text-align: center !important;
    -fx-alignment: center !important;
}

/* Fix Actions Icon Color (3 dots) */
.btn-icon .svg-path {
    -fx-stroke: -fx-muted-foreground;
}
.btn-icon:hover .svg-path {
    -fx-stroke: -fx-foreground;
}
.btn-icon:pressed .svg-path {
    -fx-stroke: -fx-foreground;
    -fx-opacity: 0.8;
}
/* ========== DIALOG STYLES ========== */
/* Modern dialog matching app window styling */

.dialog-pane {
    -fx-background-color: -fx-card;
    -fx-background-radius: 12px;
    -fx-border-radius: 12px;
    -fx-border-color: -fx-border;
    -fx-border-width: 1px;
    -fx-padding: 0;
    -fx-min-width: 420px;
    -fx-max-width: 520px;
    -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.2), 10, 0, 0, 4);
}

.dialog-pane > .content {
    -fx-padding: 0;
}

/* Dialog Header (shadcn DialogHeader: flex flex-col space-y-1.5) */
.dialog-header {
    -fx-background-color: transparent;    /* No gradient - clean flat like shadcn */
    -fx-padding: 24px;                    /* p-6 = 24px */
    -fx-spacing: 6;                       /* space-y-1.5 = 6px */
    -fx-border-color: transparent;        /* No border under header */
    -fx-border-width: 0;
}

/* DialogTitle: text-lg font-semibold leading-none tracking-tight */
.dialog-title {
    -fx-font-size: 18px;                  /* text-lg = 18px */
    -fx-font-weight: 600;                 /* font-semibold */
    -fx-text-fill: -fx-popover-foreground;
}

/* DialogDescription: text-sm text-muted-foreground */
.dialog-description {
    -fx-font-size: 14px;                  /* text-sm */
    -fx-text-fill: -fx-muted-foreground;
    -fx-wrap-text: true;
}

/* Dialog Content Area (shadcn: gap-4 = 16px) */
.dialog-content {
    -fx-padding: 0 24px 24px 24px;        /* p-6 minus top (header has it) */
    -fx-spacing: 16;                      /* gap-4 = 16px */
    -fx-background-color: transparent;    /* Same bg as dialog container */
}


/* Dialog Footer / Button Bar (shadcn DialogFooter: justify-end space-x-2) */

.dialog-pane > .button-bar {
    -fx-background-color: -fx-popover;
    -fx-padding: 16 24;
    -fx-border-color: -fx-border transparent transparent transparent;
    -fx-border-width: 1 0 0 0;
    -fx-background-radius: 0 0 8px 8px;
}

.dialog-pane > .button-bar > .container {
    -fx-spacing: 12;
    -fx-alignment: center-right;
}

/* Dialog buttons */
.dialog-pane .button {
    -fx-font-size: 13px;
    -fx-font-weight: 500;
    -fx-padding: 10 20;
    -fx-background-radius: 6px;
    -fx-border-radius: 6px;
    -fx-cursor: hand;
}

/* Primary action button (OK/Save) */
.dialog-pane .button.default,
.dialog-pane .button-bar .button:default {
    -fx-background-color: -fx-primary;
    -fx-text-fill: -fx-primary-foreground;
    -fx-border-color: transparent;
}
.dialog-pane .button.default:hover,
.dialog-pane .button-bar .button:default:hover {
    -fx-background-color: derive(-fx-primary, -10%);
}

/* Cancel button */
.dialog-pane .button.cancel,
.dialog-pane .button-bar .button:cancel,
.dialog-pane .button-bar .button:not(:default) {
    -fx-background-color: transparent;
    -fx-text-fill: -fx-foreground;
    -fx-border-color: -fx-border;
    -fx-border-width: 1px;
}
.dialog-pane .button.cancel:hover,
.dialog-pane .button-bar .button:cancel:hover,
.dialog-pane .button-bar .button:not(:default):hover {
    -fx-background-color: -fx-muted;
}

/* Fix header positioning for styled dialogs */
.dialog-pane:header .header-panel {
    -fx-background-color: transparent;
    -fx-padding: 0;
}

/* Make header text invisible since we use custom header */
.dialog-pane > .header-panel > .label {
    visibility: hidden;
    -fx-min-height: 0;
    -fx-pref-height: 0;
    -fx-max-height: 0;
}



/* Ensure dialog text inputs look clean */
.dialog-content .text-input {
    -fx-background-color: -fx-input;
    -fx-background-radius: 6px;
    -fx-border-radius: 6px;
}

/* Fix select/combo-box text visibility in dialogs */
.dialog-content .select-trigger,
.dialog-content .combo-box-base,
.dialog-content .combo-box {
    -fx-text-fill: -fx-foreground;
}

.dialog-content .select-trigger .list-cell,
.dialog-content .combo-box .list-cell {
    -fx-text-fill: -fx-foreground;
}

.dialog-content .combo-box .list-cell:filled,
.dialog-content .select-trigger .list-cell:filled {
    -fx-text-fill: -fx-foreground;
}

.dialog-content .combo-box-base .text,
.dialog-content .combo-box .text {
    -fx-fill: -fx-foreground;
}

/* Form section styles */
.dialog-form-section {
    -fx-padding: 0 0 12 0;
}

.dialog-section-title {
    -fx-font-size: 12px;
    -fx-font-weight: 600;
    -fx-text-fill: -fx-primary;
    -fx-padding: 0 0 8 0;
    -fx-border-color: transparent transparent derive(-fx-border, 20%) transparent;
    -fx-border-width: 0 0 1 0;
}

/* Light mode adjustments */
.root.light .dialog-pane {
    -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.12), 10, 0, 0, 4);
}

.root.light .dialog-header {
    -fx-background-color: linear-gradient(to bottom, -fx-card, derive(-fx-card, -2%));
}
/* ========== JOB CARD ========== */
.job-card {
    -fx-background-color: -fx-card;
    -fx-background-radius: 12;
    -fx-border-color: -fx-border;
    -fx-border-radius: 12;
    -fx-border-width: 1;
    -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.12), 6, 0, 0, 2);
}

.job-card-clickable {
    -fx-cursor: hand;
}
.job-card-clickable:hover {
    -fx-background-color: -fx-muted;
    -fx-border-color: -fx-ring;
    -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.25), 14, 0, 0, 4);
}
.job-card-clickable:focused {
    -fx-border-color: -fx-ring;
    -fx-border-width: 2;
}
.job-card-clickable:pressed {
    -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.10), 4, 0, 0, 1);
    -fx-scale-x: 0.99;
    -fx-scale-y: 0.99;
}

.job-card-title {
    -fx-font-size: 16px;
    -fx-font-weight: bold;
    -fx-text-fill: -fx-foreground;
}

.job-card-source {
    -fx-font-size: 12px;
    -fx-text-fill: -fx-muted-foreground;
}

.job-card-desc {
    -fx-text-fill: -fx-foreground;
    -fx-font-size: 13px;
    -fx-opacity: 0.85;
}

.job-card-badge {
    -fx-background-color: -fx-muted;
    -fx-text-fill: -fx-foreground;
    -fx-padding: 4 8;
    -fx-background-radius: 6;
    -fx-font-size: 11px;
}

/* Bookmark toggle button (R-05) */
.bookmark-toggle {
    -fx-background-color: transparent;
    -fx-padding: 4;
    -fx-cursor: hand;
    -fx-background-radius: 6;
    -fx-min-width: 28;
    -fx-min-height: 28;
    -fx-max-width: 28;
    -fx-max-height: 28;
}
.bookmark-toggle:hover {
    -fx-background-color: -fx-muted;
}
.bookmark-toggle:focused {
    -fx-background-color: -fx-muted;
    -fx-border-color: -fx-ring;
    -fx-border-width: 1;
    -fx-border-radius: 6;
}
/* ========== NOTIFICATION GROUPING (C-10) ========== */
.notification-date-header {
    -fx-font-size: 12px;
    -fx-font-weight: bold;
    -fx-text-fill: -fx-muted-foreground;
    -fx-padding: 12px 0 4px 0;
}

/* ========== STEP INDICATOR (Forgot Password) ========== */
.step-indicator { -fx-padding: 0 0 28 0; }
.step-circle-active {
    -fx-background-color: -fx-primary;
    -fx-background-radius: 16;
}
.step-circle-done {
    -fx-background-color: -fx-green;
    -fx-background-radius: 16;
}
.step-circle-inactive {
    -fx-background-color: -fx-muted;
    -fx-background-radius: 16;
}
.step-number-active {
    -fx-font-size: 13px;
    -fx-font-weight: 700;
    -fx-text-fill: -fx-primary-foreground;
}
.step-number-inactive {
    -fx-font-size: 13px;
    -fx-font-weight: 700;
    -fx-text-fill: -fx-muted-foreground;
}
.step-text-active {
    -fx-font-size: 11px;
    -fx-text-fill: -fx-foreground;
}
.step-text-inactive {
    -fx-font-size: 11px;
    -fx-text-fill: -fx-muted-foreground;
}
.step-connector {
    -fx-background-color: -fx-muted;
    -fx-background-radius: 1;
}
.step-connector-active {
    -fx-background-color: -fx-primary;
    -fx-background-radius: 1;
}
/* ========== KANBAN BOARD (Applications) ========== */
/* ========== TAB BUTTON (toggle tab style) ========== */
.tab-button {
    -fx-background-color: transparent;
    -fx-background-radius: 6px;
    -fx-border-color: transparent;
    -fx-border-width: 1px;
    -fx-border-radius: 6px;
    -fx-padding: 6px 16px;
    -fx-font-size: 13px;
    -fx-font-weight: 500;
    -fx-text-fill: -fx-muted-foreground;
    -fx-cursor: hand;
}
.tab-button:hover {
    -fx-background-color: -fx-muted;
    -fx-text-fill: -fx-foreground;
}
.tab-button:focused {
    -fx-border-color: -fx-ring;
}
.tab-button:selected,
.tab-button-active {
    -fx-background-color: -fx-muted;
    -fx-text-fill: -fx-foreground;
    -fx-font-weight: 600;
}

.kanban-column {
    -fx-background-radius: 8;
    -fx-padding: 16;
}
.kanban-col-applied { -fx-background-color: -fx-muted; }
.kanban-col-review { -fx-background-color: derive(-fx-blue, 90%); }
.kanban-col-interview { -fx-background-color: derive(-fx-amber, 90%); }
.kanban-col-offer { -fx-background-color: derive(-fx-green, 90%); }

.root.dark .kanban-col-review { -fx-background-color: derive(-fx-blue, -70%); }
.root.dark .kanban-col-interview { -fx-background-color: derive(-fx-amber, -70%); }
.root.dark .kanban-col-offer { -fx-background-color: derive(-fx-green, -70%); }
/* ========== AUTH HERO TEXT ========== */
.hero-icon { -fx-fill: -fx-foreground; }
.hero-brand {
    -fx-font-size: 20px;
    -fx-font-weight: bold;
    -fx-text-fill: -fx-foreground;
}
.hero-heading {
    -fx-font-size: 24px;
    -fx-font-weight: bold;
    -fx-text-fill: -fx-foreground;
}
.hero-subtitle {
    -fx-font-size: 14px;
    -fx-text-fill: -fx-muted-foreground;
}
.hero-content { -fx-padding: 48; }

/* Light theme overrides for hero text */
.root.light .hero-icon { -fx-fill: -fx-foreground; }
.root.light .hero-brand { -fx-text-fill: -fx-foreground; }
.root.light .hero-heading { -fx-text-fill: -fx-foreground; }
.root.light .hero-subtitle { -fx-text-fill: -fx-muted-foreground; }
/* ========== FORGOT PASSWORD VIEW ========== */
.forgot-header { -fx-padding: 0 0 24 0; }
.forgot-icon { -fx-font-size: 40px; }
.forgot-link {
    -fx-padding: 0;
    -fx-font-size: 13px;
    -fx-text-fill: -fx-muted-foreground;
    -fx-underline: true;
}
.text-success { -fx-text-fill: -fx-success; }
.link-inline { -fx-padding: 0; }
/* ========== BIOMETRIC AUTH DIALOG ========== */
.biometric-dialog-card {
    -fx-border-color: -fx-border;
    -fx-border-width: 1;
    -fx-background-radius: 16;
    -fx-border-radius: 16;
    -fx-background-color: -fx-card;
    -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.5), 30, 0, 0, 8);
}
.camera-frame {
    -fx-background-color: -fx-background;
    -fx-background-radius: 14;
    -fx-border-color: -fx-border;
    -fx-border-width: 1;
    -fx-border-radius: 14;
}
.camera-guides {
    -fx-stroke: -fx-foreground;
    -fx-stroke-width: 3;
}
.icon-primary { -fx-fill: -fx-primary; }
/* ========== ERROR VIEW ========== */
.error-icon { -fx-font-size: 96px; }
.error-code {
    -fx-font-size: 72px;
    -fx-font-weight: bold;
}
.text-xs-mono {
    -fx-font-size: 11px;
    -fx-font-family: monospace;
}
/* ========== TOPBAR NOTIFICATION BELL ========== */
.topbar-icon-btn {
    -fx-background-color: transparent;
    -fx-border-color: -fx-border;
    -fx-border-width: 1px;
    -fx-border-radius: 6px;
    -fx-background-radius: 6px;
    -fx-padding: 6;
    -fx-cursor: hand;
    -fx-min-width: 34;
    -fx-max-width: 34;
    -fx-min-height: 34;
    -fx-max-height: 34;
}
.topbar-icon-btn:hover {
    -fx-background-color: -fx-muted;
}
.topbar-icon-btn:focused {
    -fx-border-color: -fx-ring;
}
.topbar-icon-btn .svg-path {
    -fx-stroke: -fx-foreground;
}

.notif-badge {
    -fx-background-color: -fx-destructive;
    -fx-text-fill: -fx-destructive-foreground;
    -fx-font-size: 9px;
    -fx-font-weight: 700;
    -fx-padding: 0 4 0 4;
    -fx-background-radius: 8;
    -fx-border-color: -fx-card;
    -fx-border-width: 2;
    -fx-border-radius: 10;
    -fx-min-width: 16px;
    -fx-min-height: 16px;
    -fx-max-height: 16px;
    -fx-alignment: center;
}

.topbar-actions {
    -fx-alignment: center-right;
    -fx-spacing: 8;
    -fx-padding: 0 10 0 0;
}

/* ========== SUPPORT MODULE ========== */

/* Priority strip on ticket cards */
.ticket-priority-strip {
    -fx-background-radius: 3;
}
.priority-low    { -fx-background-color: -fx-muted-foreground; }
.priority-medium { -fx-background-color: -fx-primary; }
.priority-high   { -fx-background-color: -fx-amber; }
.priority-urgent { -fx-background-color: -fx-destructive; }

/* Info strip below ticket detail header */
.ticket-info-strip {
    -fx-background-color: -fx-muted;
    -fx-background-radius: 8;
}

/* Description box */
.ticket-description-box {
    -fx-background-color: -fx-card;
    -fx-background-radius: 8;
    -fx-border-color: -fx-border;
    -fx-border-width: 1;
    -fx-border-radius: 8;
}

/* Reply input bar at bottom */
.ticket-reply-bar {
    -fx-background-color: -fx-card;
    -fx-border-color: -fx-border transparent transparent transparent;
    -fx-border-width: 1 0 0 0;
}
.chatbot-input-bar {
    -fx-background-color: -fx-card;
    -fx-border-color: -fx-border transparent transparent transparent;
    -fx-border-width: 1 0 0 0;
}

/* Reply text input */
.reply-input {
    -fx-background-color: -fx-input;
    -fx-background-radius: 20;
    -fx-border-color: -fx-border;
    -fx-border-radius: 20;
    -fx-border-width: 1;
    -fx-padding: 8 16;
    -fx-font-size: 13px;
    -fx-text-fill: -fx-foreground;
    -fx-prompt-text-fill: -fx-muted-foreground;
}
.reply-input:focused {
    -fx-border-color: -fx-ring;
    -fx-effect: none;
}

/* Send button circle */
.send-btn {
    -fx-min-width: 36px;
    -fx-max-width: 36px;
    -fx-min-height: 36px;
    -fx-max-height: 36px;
    -fx-padding: 0;
    -fx-background-radius: 18;
}
.send-btn .svg-path {
    -fx-stroke: -fx-primary-foreground;
    -fx-fill: transparent;
}
.send-btn:hover .svg-path {
    -fx-stroke: -fx-primary-foreground;
}

/* Date separator in conversation */
.date-separator-label {
    -fx-background-color: -fx-muted;
    -fx-padding: 3 10;
    -fx-background-radius: 10;
    -fx-font-size: 11px;
}

/* FAQ items */
.faq-item {
    -fx-background-color: -fx-card;
    -fx-background-radius: 8;
    -fx-border-color: -fx-border;
    -fx-border-width: 1;
    -fx-border-radius: 8;
}
.faq-item:hover {
    -fx-border-color: -fx-ring;
}

/* Scrollbar slim style for message areas */
.msg-scroll .scroll-bar:vertical {
    -fx-pref-width: 6px;
    -fx-padding: 2px 1px;
}
.msg-scroll .scroll-bar:vertical .track {
    -fx-background-color: transparent;
}
.msg-scroll .scroll-bar:vertical .thumb {
    -fx-background-color: -fx-muted-foreground;
    -fx-background-radius: 3px;
    -fx-opacity: 0.3;
}
.msg-scroll .scroll-bar:vertical .thumb:hover {
    -fx-opacity: 0.5;
}
.msg-scroll .scroll-bar:vertical .increment-button,
.msg-scroll .scroll-bar:vertical .decrement-button {
    -fx-pref-height: 0;
    -fx-min-height: 0;
    -fx-max-height: 0;
}

/* ========== MISC VIEW STYLES ========== */
.bg-muted-rounded {
    -fx-background-color: -fx-muted;
    -fx-background-radius: 8;
}
