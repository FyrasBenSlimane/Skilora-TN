# ═══════════════════════════════════════════════════════════════
# Skilora Tunisia — Environment Configuration Template
# ═══════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your actual values.
# NEVER commit the .env file to version control.
# ═══════════════════════════════════════════════════════════════

# ── Database ──
SKILORA_DB_URL=jdbc:mysql://localhost:3306/skilora
SKILORA_DB_USER=root
SKILORA_DB_PASSWORD=

# ── Stripe (Finance — Payment Processing) ──
STRIPE_SECRET_KEY=sk_test_YOUR_KEY_HERE
STRIPE_PUBLIC_KEY=pk_test_YOUR_KEY_HERE

# ── Twilio (WhatsApp / SMS Notifications) ──
TWILIO_ACCOUNT_SID=AC_YOUR_SID_HERE
TWILIO_AUTH_TOKEN=YOUR_TOKEN_HERE
TWILIO_FROM_NUMBER=whatsapp:+14155238886
TWILIO_TO_NUMBER=whatsapp:+216XXXXXXXX

# ── Google Gemini AI ──
GEMINI_API_KEY=YOUR_GEMINI_KEY_HERE

# ── OpenAI (Finance Chatbot) ──
OPENAI_API_KEY=sk-YOUR_OPENAI_KEY_HERE

# ── Cloudinary (Media Uploads) ──
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_UPLOAD_PRESET=your_upload_preset
CLOUDINARY_API_KEY=YOUR_CLOUDINARY_KEY_HERE
CLOUDINARY_API_SECRET=YOUR_CLOUDINARY_SECRET_HERE

# ── Deepgram (Speech-to-Text) ──
DEEPGRAM_API_KEY=YOUR_DEEPGRAM_KEY_HERE

# ── Email / SMTP ──
SKILORA_MAIL_EMAIL=your_email@gmail.com
SKILORA_MAIL_PASSWORD=your_app_password

# ── Groq AI ──
GROQ_API_KEY=YOUR_GROQ_KEY_HERE
GROQ_MODEL=llama-3.1-8b-instant

# ── Model Defaults ──
DEEPGRAM_MODEL=nova-2
GEMINI_MODEL=gemini-2.0-flash
